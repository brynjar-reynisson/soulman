{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "supabase": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote@latest", "http://127.0.0.1:54321/mcp", "--allow-http"],
      "enabled": true
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "${root}"],
      "enabled": true
    },
    "soulman": {
      "type": "local",
      "command": ["python", "${root}/soulman-memory-mcp-server.py"],
      "enabled": true
    }
  },
  "tools": {
    "supabase_*": true,
    "filesystem_*": true,
    "soulman_*": true
  }
}
