# Copy this to .env (dev), .env.production, and .env.test, filling in real
# values for each environment. None of the four are committed - see
# .gitignore.

# The hosted Supabase project's URL and anon key (same project agent-suite
# uses). The anon key is safe to expose client-side by design, but is kept
# out of git here for consistency with the other three vars.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Where Supabase should redirect back to after Google OAuth completes -
# this frontend's own URL for the environment (must also be added to the
# Supabase project's Auth > URL Configuration > Redirect URLs allowlist).
VITE_AUTH_REDIRECT_URL=http://localhost:5190

# Base URL of the web-svc backend for this environment.
VITE_WEB_SVC_URL=http://localhost:9015
